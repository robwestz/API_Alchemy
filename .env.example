# .env.example - kopiera till .env och fyll i dina varden
# Se ENV_SETUP.md for Postgres-installationsinstruktioner.
# Committa ALDRIG .env till git - den ar redan i .gitignore.

# Postgres DSN (Neon free tier eller lokal Postgres)
DATABASE_URL=postgres://user:pass@host/db

# LiteLLM log-niva (ERROR rekommenderat for att undvika token-lage i logs)
LITELLM_LOG=ERROR

# LLM API-nycklar - lamna tomma om du inte anvander respektive leverantor
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Applikations log-niva (DEBUG | INFO | WARNING | ERROR)
LOG_LEVEL=INFO
